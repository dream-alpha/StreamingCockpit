	<widget backgroundColor="$black" cornerRadius="300" name="background" position="center,center" size="eval($screen_width*0.3),eval($screen_height*0.4)" zPosition="2"/>
	<widget alphatest="blend" name="pic_loading" position="center,eval($screen_height/2-100)" size="100,100" zPosition="3"/>
	<widget font="Regular;40" halign="center" name="int_loading" position="center,eval($screen_height/2-100)" size="80,80" transparent="1" valign="center" zPosition="4"/>
	<widget font="Regular;40" halign="center" name="msg_loading" position="center,eval($screen_height/2+20)" size="$screen_width,80" transparent="1" valign="center" zPosition="4"/>
